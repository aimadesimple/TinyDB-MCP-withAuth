# Auth0 tenant domain, without https://
AUTH0_DOMAIN=your-tenant.us.auth0.com

# Auth0 API identifier and public MCP endpoint. These values must match.
AUTH0_AUDIENCE=https://tinydb-mcp-withauth.onrender.com/mcp
MCP_SERVER_URL=https://tinydb-mcp-withauth.onrender.com/mcp

# Every authenticated user must receive this Auth0 API permission.
AUTH0_REQUIRED_SCOPE=tinydb:tools

# Local development settings
HOST=0.0.0.0
PORT=10000
